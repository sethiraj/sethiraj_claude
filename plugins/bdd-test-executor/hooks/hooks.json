{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/scan-features.sh\"",
            "timeout": 15000,
            "blocking": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_playwright_playwright__browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/validate-playwright.sh\"",
            "timeout": 60000,
            "blocking": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_playwright_playwright__browser_close",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/collect-results.sh\"",
            "timeout": 15000,
            "blocking": false
          }
        ]
      }
    ]
  }
}
